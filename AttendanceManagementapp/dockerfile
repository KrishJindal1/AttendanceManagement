# Step 1: Build stage (Using Java 21 to run Maven, as it's stable)
# Step 1: Build stage (Using Java 25 to match your code)
FROM eclipse-temurin:25-jdk-alpine AS build
WORKDIR /app

# Copy the wrapper and pom first (helps with caching)
COPY .mvn/ .mvn
COPY mvnw pom.xml ./
RUN chmod +x mvnw

# Copy the source code and build the JAR
COPY src ./src
RUN ./mvnw clean package -DskipTests

# Step 2: Runtime stage (Using Java 25 for running the app)
FROM eclipse-temurin:25-jdk-alpine
WORKDIR /app

# Copy the compiled .jar from the build stage
COPY --from=build /app/target/*.jar app.jar

EXPOSE 8080

# Optimization: Limit memory for Render's free tier
ENTRYPOINT ["java", "-Xmx300m", "-Xss512k", "-jar", "app.jar"]